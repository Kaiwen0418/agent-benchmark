{
  "name": "agentbench",
  "private": true,
  "version": "0.1.0",
  "license": "SEE LICENSE IN LICENSE",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter web dev",
    "dev:orchestrator": "pnpm --filter hosted-orchestrator dev",
    "dev:hosted": "pnpm --filter hosted-sites dev",
    "infra:up": "docker-compose up -d --build",
    "infra:down": "docker-compose down",
    "infra:logs": "docker-compose logs -f --tail=200",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:coverage": "bash scripts/test-coverage.sh",
    "catalog:generate": "pnpm --filter @agentbench/test-cases generate-catalog",
    "catalog:check": "pnpm --filter @agentbench/test-cases check-catalog",
    "hosted-app:check": "node scripts/check-hosted-app-consistency.mjs",
    "create-hosted-app": "node scripts/create-hosted-app.mjs",
    "catalog:publish": "pnpm --filter @agentbench/test-cases run publish",
    "smoke:local": "bash tests/e2e/smoke-local.sh",
    "smoke:lifecycle": "bash tests/e2e/hosted-lifecycle-full-pass.sh",
    "db:migrate:test": "bash scripts/db-migrate.sh test",
    "db:migrate:test:dry-run": "bash scripts/db-migrate.sh test --dry-run",
    "db:migrate:prod": "bash scripts/db-migrate.sh production",
    "db:migrate:prod:dry-run": "bash scripts/db-migrate.sh production --dry-run",
    "verify:ci": "bash scripts/verify-ci.sh",
    "verify:push": "bash scripts/verify-pre-push.sh",
    "hooks:install": "sh scripts/install-git-hooks.sh",
    "prepare": "sh scripts/install-git-hooks.sh"
  },
  "devDependencies": {
    "turbo": "^2.10.0"
  }
}
