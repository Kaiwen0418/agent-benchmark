{
  "name": "agentbench",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter web dev",
    "dev:orchestrator": "pnpm --filter hosted-orchestrator dev",
    "dev:runner": "pnpm --filter runner dev",
    "dev:mock": "pnpm --filter mock-sites dev",
    "dev:hosted": "pnpm --filter hosted-sites dev",
    "infra:up": "docker-compose up -d --build",
    "infra:down": "docker-compose down",
    "infra:logs": "docker-compose logs -f --tail=200",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  }
}
