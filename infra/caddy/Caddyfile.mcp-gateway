:80 {
  encode zstd gzip

  @mcp path /mcp*
  handle @mcp {
    reverse_proxy runner-mcp:8080
  }

  @mock path /mock* /web-search* /invoice-download* /email-draft* /safety-test*
  handle @mock {
    reverse_proxy mock-sites:3001
  }

  respond /healthz 200 {
    body "{\"ok\":true,\"service\":\"mcp-gateway\"}"
    close
  }

  respond 404
}
