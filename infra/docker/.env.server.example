# Image references pushed by CI (GHCR or your registry)
HOSTED_SITES_IMAGE=ghcr.io/your-org/agentbench-hosted-sites
HOSTED_ORCHESTRATOR_IMAGE=ghcr.io/your-org/agentbench-hosted-orchestrator
HOSTED_SITES_IMAGE_TAG=latest-main
HOSTED_ORCHESTRATOR_IMAGE_TAG=latest-main

# Runtime environment
AGENTBENCH_WEB_URL=https://agent-benchmark-web.vercel.app
RUNNER_SHARED_SECRET=replace-with-strong-random-secret
HOSTED_SITES_PUBLIC_URL=https://hosted.project-echo.xyz
HOSTED_ORCHESTRATOR_URL=http://hosted-orchestrator:3004
HOSTED_ORCHESTRATOR_PUBLIC_URL=https://hosted.project-echo.xyz/orchestrator
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
HOSTED_SESSION_SWEEP_INTERVAL_MS=60000
HOSTED_SESSION_TERMINAL_RETENTION_MS=1800000
HOSTED_ACCESS_LOG_RETENTION_MS=1209600000
ORCHESTRATOR_DLQ_DEAD_RETENTION_MS=7776000000
ORCHESTRATOR_DLQ_RESOLVED_RETENTION_MS=2592000000
ORCHESTRATOR_DLQ_PRUNE_BATCH_SIZE=500
HOSTED_SESSION_REDIS_URL=redis://redis:6379
ORCHESTRATOR_REDIS_URL=redis://redis:6379
ORCHESTRATOR_PARTITION_COUNT=16
ORCHESTRATOR_WORKER_0_PARTITIONS=0,1,2,3,4,5,6,7
ORCHESTRATOR_WORKER_1_PARTITIONS=8,9,10,11,12,13,14,15
HOSTED_SESSION_REDIS_TTL_MS=21600000
REDIS_IMAGE=redis:7-alpine
