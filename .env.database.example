# Local development and the deployed test environment intentionally share this database.
# Raw passwords are accepted; the migration script URL-encodes credentials before invoking Supabase CLI.
TEST_SUPABASE_DB_URL=postgresql://postgres:<encoded-password>@db.<test-project-ref>.supabase.co:5432/postgres

# Production must always use a separate Supabase project and secret.
PROD_SUPABASE_DB_URL=postgresql://postgres:<encoded-password>@db.<production-project-ref>.supabase.co:5432/postgres
