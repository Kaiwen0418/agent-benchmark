{
  "name": "runner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:mcp": "tsx watch src/mcp-server.ts",
    "dev:mcp:http": "tsx watch src/mcp-http-server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/apps/runner/src/index.js",
    "start:mcp": "node dist/apps/runner/src/mcp-server.js",
    "start:mcp:http": "node dist/apps/runner/src/mcp-http-server.js"
  },
  "dependencies": {
    "@agentbench/mcp-tools": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.17.5",
    "@agentbench/protocol": "workspace:*",
    "playwright": "^1.55.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
