{
  "name": "hosted-orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "test:questions": "node --import tsx --test src/question-*.test.ts",
    "test": "node --import tsx --test src/*.test.ts src/**/*.test.ts",
    "start": "node dist/apps/hosted-orchestrator/src/server.js"
  },
  "dependencies": {
    "@agentbench/scoring": "workspace:*",
    "@agentbench/shared": "workspace:*",
    "@supabase/supabase-js": "^2.108.2",
    "redis": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3"
  }
}
