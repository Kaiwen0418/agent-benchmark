{
  "name": "hosted-orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "test:questions": "node --import tsx --test tests/unit/question-*.test.ts",
    "test": "node --import tsx --test $(find tests/unit -type f -name '*.test.ts' | sort)",
    "start": "node dist/apps/hosted-orchestrator/src/server.js"
  },
  "dependencies": {
    "@agentbench/protocol": "workspace:*",
    "@agentbench/scoring": "workspace:*",
    "@agentbench/shared": "workspace:*",
    "@agentbench/test-cases": "workspace:*",
    "@supabase/supabase-js": "^2.110.2",
    "redis": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "tsx": "^4.23.1",
    "typescript": "^5.7.3"
  }
}
