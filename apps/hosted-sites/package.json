{
  "name": "hosted-sites",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "test:questions": "node --import tsx --test src/evaluation.test.ts src/templates.test.ts src/runtime/question-config.test.ts",
    "test": "node --import tsx --test src/*.test.ts src/**/*.test.ts",
    "start": "node dist/apps/hosted-sites/src/server.js"
  },
  "dependencies": {
    "@agentbench/scoring": "workspace:*",
    "@agentbench/shared": "workspace:*",
    "@supabase/supabase-js": "^2.49.1",
    "redis": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
