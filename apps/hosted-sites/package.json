{
  "name": "hosted-sites",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "generate-registry": "node scripts/generate-app-registry.mjs",
    "check-registry": "node scripts/generate-app-registry.mjs --check",
    "build": "pnpm run check-registry && tsc -p tsconfig.json",
    "test:questions": "node --import tsx --test tests/unit/evaluation.test.ts tests/unit/templates.test.ts tests/unit/runtime/question-config.test.ts",
    "test": "pnpm run check-registry && node --import tsx --test $(find tests/unit -type f -name '*.test.ts' | sort)",
    "start": "node dist/apps/hosted-sites/src/server.js"
  },
  "dependencies": {
    "@agentbench/scoring": "workspace:*",
    "@agentbench/shared": "workspace:*",
    "@agentbench/test-cases": "workspace:*",
    "redis": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "tsx": "^4.23.1",
    "typescript": "^5.7.3"
  }
}
