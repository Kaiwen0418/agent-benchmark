{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@agentbench/protocol": ["packages/protocol/src/index.ts"],
      "@agentbench/protocol/*": ["packages/protocol/src/*"],
      "@agentbench/scoring": ["packages/scoring/src/index.ts"],
      "@agentbench/scoring/*": ["packages/scoring/src/*"],
      "@agentbench/shared": ["packages/shared/src/index.ts"],
      "@agentbench/shared/*": ["packages/shared/src/*"]
    }
  }
}
