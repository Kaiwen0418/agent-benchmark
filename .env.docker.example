# Public web control plane URL (used by hosted-sites callbacks)
AGENTBENCH_WEB_URL=https://agent-benchmark-web.vercel.app

# Shared secret between hosted-sites and web run event/completion routes
RUNNER_SHARED_SECRET=replace-with-strong-random-secret

# Public URL exposed by your tunnel / domain for hosted-sites
HOSTED_SITES_PUBLIC_URL=https://hosted.project-echo.xyz

# Supabase service role is only used server-side by hosted-sites persistence.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Local host port for the hosted-sites gateway.
# Change this if another local process already uses 8080.
GATEWAY_HTTP_PORT=8080
