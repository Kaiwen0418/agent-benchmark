# Public web control plane URL (used by runner callbacks and live links)
AGENTBENCH_WEB_URL=https://agent-benchmark-web.vercel.app

# Shared secret between runner and web /api/runners* routes
RUNNER_SHARED_SECRET=replace-with-strong-random-secret

# Public URL exposed by your tunnel / domain for MCP
RUNNER_MCP_PUBLIC_BASE_URL=https://mcp.project-echo.xyz

# Local host port for the Docker gateway.
# Change this if another local process already uses 8080.
GATEWAY_HTTP_PORT=8080
